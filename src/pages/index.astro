			}

			.contribution-week {
				display: flex;
				gap: 3px;
			}

			.contribution-day {
				width: 12px;
				height: 12px;
				cursor: pointer;
				transition: all 0.3s;
				border: 1px solid rgba(95, 237, 131, 0.2);
			}

			.contribution-day:hover {
				transform: scale(1.5);
				box-shadow: 0 0 10px currentColor;
				z-index: 10;
			}

			.grid-placeholder {
				padding: 20px;
				text-align: center;
				color: #666;
				background: rgba(0, 0, 0, 0.3);
				font-size: 0.7rem;
			}

			.vs-badge {
				text-align: center;
				font-weight: bold;
				font-size: 1.3rem;
				color: #5fed83;
				background: rgba(10, 10, 26, 0.9);
				padding: 12px 20px;
				border: 2px solid #5fed83;
				align-self: center;
				margin: -10px 0;
				z-index: 10;
				box-shadow: 0 0 20px rgba(95, 237, 131, 0.5);
				text-shadow: 0 0 10px #5fed83;
				animation: gradientShift 3s ease infinite;
				font-family: 'Press Start 2P', cursive;
			}

			.winner-badge {
				display: inline-block;
				background: #8a2be2;
				color: white;
				padding: 6px 12px;
				font-size: 0.6rem;
				font-weight: bold;
				margin-left: 10px;
				box-shadow: 0 0 15px rgba(138, 43, 226, 0.8);
				animation: badgePulse 1s ease-in-out infinite;
			}

			@keyframes badgePulse {
				0%, 100% {
					transform: scale(1);
				}
				50% {
					transform: scale(1.05);
				}
			}

			.battle-summary {
				text-align: center;
				margin-top: 20px;
				padding: 20px;
				background: rgba(138, 43, 226, 0.2);
				border: 2px solid #8a2be2;
				font-size: 0.8rem;
				font-weight: bold;
				color: #8a2be2;
				text-shadow: 0 0 10px #8a2be2;
				box-shadow: 0 0 20px rgba(138, 43, 226, 0.4);
				line-height: 1.6;
			}
		</style>

		<script>
			const player1Input = document.getElementById('player1') as HTMLInputElement;
			const player2Input = document.getElementById('player2') as HTMLInputElement;
			const battleBtn = document.getElementById('battleBtn') as HTMLButtonElement;
			const errorDiv = document.getElementById('error') as HTMLDivElement;
			const loadingDiv = document.getElementById('loading') as HTMLDivElement;
			const resultsDiv = document.getElementById('results') as HTMLDivElement;

			/**
			 * Represents a single day's contribution data in GitHub's contribution graph.
			 * GitHub provides contribution data with levels 0-4 indicating intensity.
			 * 
			 * @interface ContributionDay
			 * @property {number} weekday - Day of week (0 = Sunday, 6 = Saturday)
			 * @property {number} count - Total contributions on this day
			 * @property {number} level - Contribution intensity level (0-4)
			 *   0 = none, 1 = low, 2 = medium, 3 = high, 4 = very high
			 */
			interface ContributionDay {
				weekday: number;
				count: number;
				level: number;
			}

			/**
			 * Represents a week of contribution data (7 days).
			 * 
			 * @interface ContributionWeek
			 * @property {number} index - Week index in the response
			 * @property {string} first_day - First day of the week (YYYY-MM-DD format)
			 * @property {ContributionDay[]} contribution_days - Array of 7 contribution day objects
			 */
			interface ContributionWeek {
				index: number;
				first_day: string;
				contribution_days: ContributionDay[];
			}

			/**
			 * Full contribution data response from GitHub API (v2 format).
			 * This is the complete structure returned by https://github.com/{username}.contribs
			 * 
			 * @interface ContributionData
			 * @property {string} schema - API version (e.g., "v2")
			 * @property {string} generated_at - ISO timestamp when data was generated
			 * @property {string} from - Start date of contribution range (YYYY-MM-DD)
			 * @property {string} to - End date of contribution range (YYYY-MM-DD)
			 * @property {number} range_days - Total days in the range
			 * @property {number} total_contributions - Sum of all contributions in range
			 * @property {boolean} private_contributions_included - Whether private repos are counted
			 * @property {string[]} colors_full - Hex color palette for visualization
			 * @property {ContributionWeek[]} weeks - Array of weeks with daily contribution data
			 * @property {Array} months - Month metadata
			 */
			interface ContributionData {
				schema: string;
				generated_at: string;
				from: string;
				to: string;
				range_days: number;
				total_contributions: number;
				private_contributions_included: boolean;
				colors_full: string[];
				weeks: ContributionWeek[];
				months: Array<{
					month: string;
					total_weeks: number;
				}>;
			}

			/**
			 * Player data used during battle comparison.
			 * Wraps contribution data with calculated totals and date ranges.
			 * 
			 * @interface PlayerData
			 * @property {string} username - GitHub username
			 * @property {number} totalContributions - Total contributions in range
			 * @property {ContributionData} data - Full API response object
			 * @property {Object} dateRange - Extracted date range
			 * @property {string} dateRange.start - Start date (YYYY-MM-DD)
			 * @property {string} dateRange.end - End date (YYYY-MM-DD)
			 */
			interface PlayerData {
				username: string;
				totalContributions: number;
				data: ContributionData;
				dateRange: {
					start: string;
					end: string;
				};
			}

			// GitHub contribution color palette (based on levels 0-4)
			// Maps contribution levels to hex colors matching GitHub's official palette
			// Level 0: No contributions (light gray)
			// Level 1-2: Light to medium activity (green shades)
			// Level 3-4: High activity (darker green shades)
			const CONTRIBUTION_COLORS: Record<number, string> = {
				0: '#ebedf0',  // No contributions
				1: '#c6e48b',  // Low activity
				2: '#40c463',  // Medium activity
				3: '#30a14e',  // High activity
				4: '#216e39'   // Very high activity
			};

			function showError(message) {
				errorDiv.textContent = message;
				errorDiv.classList.add('show');
			}

			function hideError() {
				errorDiv.textContent = '';
				errorDiv.classList.remove('show');
			}

			function showLoading(message = 'Fetching battle data') {
				loadingDiv.textContent = message;
				loadingDiv.classList.add('show');
			}

			function hideLoading() {
				loadingDiv.textContent = '';
				loadingDiv.classList.remove('show');
			}

			/**
			 * Clears all result data from the results container and hides it.
			 * Called before starting a new battle to ensure clean state.
			 */
			function hideResults() {
				resultsDiv.innerHTML = '';
				resultsDiv.classList.remove('show');
			}

			/**
			 * Fetches a user's contribution data from the server API.
			 * The API proxy handles GitHub rate limiting and CORS.
			 * Contributions are cached server-side for 5 minutes.
			 * 
			 * @async
			 * @param {string} username - GitHub username to fetch data for
			 * @returns {Promise<ContributionData>} The contribution data or throws on error
			 * @throws {Error} If username is not found or API returns error
			 * 
			 * @example
			 * const data = await fetchContributions('torvalds');
			 * console.log(data.total_contributions); // 2986
			 */
			async function fetchContributions(username: string): Promise<ContributionData> {
				const response = await fetch(`/api/contributions/${username}`);
				
				if (!response.ok) {
					const error = await response.json();
					throw new Error(error.error || `Failed to fetch data for ${username}`);
				}

				return await response.json();
			}

			/**
			 * Calculates the total contribution count from contribution data.
			 * Safely extracts the total_contributions field with null-checks.
			 * 
			 * @param {ContributionData} data - Contribution data object
			 * @returns {number} Total contributions, or 0 if data is invalid
			 * 
			 * @example
			 * const total = calculateTotalContributions(data);
			 * console.log(total.toLocaleString()); // "2,986"
			 */
			function calculateTotalContributions(data: ContributionData): number {
				if (!data || typeof data.total_contributions !== 'number') {
					console.error('Invalid contribution data structure:', data);
					return 0;
				}
				return data.total_contributions;
			}

			/**
			 * Generates HTML for a contribution graph grid visualization.
			 * Creates a week-by-week grid where each day is a colored square based on contribution level.
			 * Uses GitHub's official color palette (levels 0-4 map to specific hex colors).
			 * 
			 * @param {ContributionData} data - Contribution data with weeks array
			 * @param {string} username - Username (for debugging, not used in output)
			 * @returns {string} HTML string containing the contribution grid, or placeholder message
			 * 
			 * @example
			 * const html = renderContributionGrid(data, 'torvalds');
			 * // Returns: '<div class="contribution-grid">...'
			 */
			function renderContributionGrid(data: ContributionData, username: string): string {
				if (!data || !Array.isArray(data.weeks) || data.weeks.length === 0) {
					return '<div class="grid-placeholder">No contribution data available</div>';
				}

				// Create grid HTML from weeks
				const weeksHTML = data.weeks.map(week => {
					if (!week || !Array.isArray(week.contribution_days)) {
						return '<div class="contribution-week"></div>';
					}
					const daysHTML = week.contribution_days.map(day => {
						if (!day) return '';
						const level = day.level || 0;
						const color = CONTRIBUTION_COLORS[level] || '#ebedf0';
						const dayName = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][day.weekday];
						return `<div class="contribution-day" style="background-color: ${color};" title="${dayName}: ${day.count} contributions"></div>`;
					}).join('');
					return `<div class="contribution-week">${daysHTML}</div>`;
				}).join('');

				return `<div class="contribution-grid">${weeksHTML}</div>`;
			}

			/**
			 * Extracts the date range from contribution data.
			 * Returns the 'from' and 'to' dates from the API response.
			 * 
			 * @param {ContributionData} data - Contribution data object
			 * @returns {Object} Date range object with start and end dates (YYYY-MM-DD format)
			 * @returns {string} .start - Start date
			 * @returns {string} .end - End date
			 * 
			 * @example
			 * const range = getDateRange(data);
			 * console.log(range); // { start: '2025-04-13', end: '2026-04-15' }
			 */
			function getDateRange(data: ContributionData): { start: string; end: string } {
				if (!data) {
					return { start: 'N/A', end: 'N/A' };
				}
				return {
					start: data.from || 'N/A',
					end: data.to || 'N/A'
				};
			}

			/**
			 * Renders the battle comparison results showing both players' data.
			 * Displays contribution graphs, totals, date ranges, and determines the winner.
			 * Winner is determined by total_contributions count.
			 * 
			 * @param {PlayerData} player1 - First player's data
			 * @param {PlayerData} player2 - Second player's data
			 * 
			 * @example
			 * displayResults(player1Data, player2Data);
			 * // Renders HTML with both players' info, graphs, and winner announcement
			 */
			function displayResults(player1: PlayerData, player2: PlayerData) {
				const isPlayer1Winner = player1.totalContributions > player2.totalContributions;
				const isPlayer2Winner = player2.totalContributions > player1.totalContributions;
				const isTie = player1.totalContributions === player2.totalContributions;

				const player1Grid = renderContributionGrid(player1.data, player1.username);
				const player2Grid = renderContributionGrid(player2.data, player2.username);

				resultsDiv.innerHTML = `
					<div class="results-container">
						<div class="player-result ${isPlayer1Winner ? 'winner' : ''}">
							<div class="player-name">
								${player1.username}
								${isPlayer1Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
							</div>
							<div class="player-stats">
								<div class="stat-row">
									<span class="stat-label">Total Contributions:</span>
									<span class="stat-value">${player1.totalContributions.toLocaleString()}</span>
								</div>
								<div class="stat-row">
									<span class="stat-label">Period:</span>
									<span class="stat-value">${player1.dateRange.start} to ${player1.dateRange.end}</span>
								</div>
							</div>
							<div class="contribution-graph-label">Last Year Activity</div>
							${player1Grid}
						</div>

						<div class="vs-badge">VS</div>

						<div class="player-result ${isPlayer2Winner ? 'winner' : ''}">
							<div class="player-name">
								${player2.username}
								${isPlayer2Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
							</div>
							<div class="player-stats">
								<div class="stat-row">
									<span class="stat-label">Total Contributions:</span>
									<span class="stat-value">${player2.totalContributions.toLocaleString()}</span>
								</div>
								<div class="stat-row">
									<span class="stat-label">Period:</span>
									<span class="stat-value">${player2.dateRange.start} to ${player2.dateRange.end}</span>
								</div>
							</div>
							<div class="contribution-graph-label">Last Year Activity</div>
							${player2Grid}
						</div>
					</div>

					<div class="battle-summary">
						${isTie ? '🤝 It\'s a tie!' : 
							isPlayer1Winner ? `🎉 ${player1.username} wins with ${(player1.totalContributions - player2.totalContributions).toLocaleString()} more contributions!` : 
							`🎉 ${player2.username} wins with ${(player2.totalContributions - player1.totalContributions).toLocaleString()} more contributions!`}
					</div>
				`;

				resultsDiv.classList.add('show');
			}

			/**
			 * Main battle orchestration function. Handles the complete battle flow:
			 * 1. Validates both input fields are filled
			 * 2. Shows loading state
			 * 3. Fetches both users' data in parallel
			 * 4. Calculates statistics (totals, date ranges)
			 * 5. Renders comparison results with winner determination
			 * 6. Handles errors and cleans up loading state
			 * 
			 * Called when:
			 * - Battle button is clicked
			 * - Enter key is pressed in either input field
			 * 
			 * @async
			 * @returns {Promise<void>}
			 * 
			 * Flow visualization:
			 * Validate inputs
			 *   ↓
			 * Show loading + disable button
			 *   ↓
			 * Fetch data in parallel (Promise.all)
			 *   ↓
			 * Validate responses
			 *   ↓
			 * Calculate stats (totals, dates)
			 *   ↓
			 * Display results + determine winner
			 *   ↓
			 * Hide loading + enable button
			 */
			async function handleBattle() {
				const username1 = player1Input.value.trim();
				const username2 = player2Input.value.trim();

				hideError();
				hideResults();

				// Validate inputs
				if (!username1 || !username2) {
					showError('Please enter both usernames');
					return;
				}

				// Disable button and show loading
				battleBtn.disabled = true;
				showLoading();

				try {
					// Fetch both users' data in parallel
					const [data1, data2] = await Promise.all([
						fetchContributions(username1),
						fetchContributions(username2)
					]);

					// Validate data structure
					if (!data1 || typeof data1 !== 'object') {
						throw new Error(`Invalid data received for user ${username1}`);
					}
					if (!data2 || typeof data2 !== 'object') {
						throw new Error(`Invalid data received for user ${username2}`);
					}

					// Calculate totals and date ranges
					const dateRange1 = getDateRange(data1);
					const dateRange2 = getDateRange(data2);

					const player1Data = {
						username: username1,
						totalContributions: calculateTotalContributions(data1),
						data: data1,
						dateRange: dateRange1
					};

					const player2Data = {
						username: username2,
						totalContributions: calculateTotalContributions(data2),
						data: data2,
						dateRange: dateRange2
					};

					// Display results
					displayResults(player1Data, player2Data);

				} catch (error) {
					console.error('Battle error:', error);
					showError(error instanceof Error ? error.message : 'An error occurred during the battle');
				} finally {
					hideLoading();
					battleBtn.disabled = false;
				}
			}

			// Attach event listener
			battleBtn.addEventListener('click', handleBattle);

			// Allow Enter key in inputs
			[player1Input, player2Input].forEach(input => {
				input.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') {
						handleBattle();
					}
				});
			});
		</script>
	</body>
</html>
