<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
	</head>
	<body>
		<main>
			<h1>🎮 Mona Mayhem</h1>
			<p class="subtitle">GitHub Contribution Battle Arena</p>

			<div class="battle-form">
				<div class="input-group">
					<label for="player1">Player 1</label>
					<input 
						type="text" 
						id="player1" 
						name="player1" 
						placeholder="Enter GitHub username"
						autocomplete="off"
					/>
				</div>

				<div class="vs">VS</div>

				<div class="input-group">
					<label for="player2">Player 2</label>
					<input 
						type="text" 
						id="player2" 
						name="player2" 
						placeholder="Enter GitHub username"
						autocomplete="off"
					/>
				</div>

				<div class="button-group">
					<button id="battleBtn" type="button">⚔️ BATTLE!</button>
					<button id="clearBtn" type="button" class="clear-btn">🗑️ CLEAR</button>
					<button id="themeBtn" type="button" class="theme-btn" title="Toggle color theme">🎨 THEME</button>
					<button id="muteBtn" type="button" class="mute-btn" title="Toggle sound">🔊 SOUND</button>
				</div>
			</div>

			<div id="error" class="error" role="alert"></div>
			<div id="loading" class="loading"></div>
			<div id="results" class="results"></div>
		</main>

		<!-- Battle Animation Overlay -->
		<div id="battleOverlay" class="battle-overlay">
			<canvas id="confettiCanvas" class="confetti-canvas"></canvas>
			<!-- Countdown Overlay -->
			<div id="countdownOverlay" class="countdown-overlay">
				<div id="countdownText" class="countdown-text">3</div>
			</div>
			<div class="battle-names">
				<div id="player1Name" class="battle-name player1-pos"></div>
				<div id="player2Name" class="battle-name player2-pos"></div>
			</div>
			<div id="pacman" class="pacman">
				<div class="pacman-body"></div>
			</div>
		</div>

		<style>
			:root {
				/* Default theme: Green & Purple */
				--color-primary: #5fed83;
				--color-secondary: #8a2be2;
				--color-accent: #ff00ff;
				--color-light-accent: #a0f0ff;
				--color-background: #0a0a1a;
				--color-border: rgba(95, 237, 131, 0.2);
				--color-glow-primary: rgba(95, 237, 131, 0.5);
				--color-glow-secondary: rgba(138, 43, 226, 0.8);
			}

			:root.theme-blue-orange {
				/* Alternative theme: Blue & Orange */
				--color-primary: #00f5ff;
				--color-secondary: #ff6b35;
				--color-accent: #ff00ff;
				--color-light-accent: #ffaa55;
				--color-background: #0a0a1a;
				--color-border: rgba(0, 245, 255, 0.2);
				--color-glow-primary: rgba(0, 245, 255, 0.5);
				--color-glow-secondary: rgba(255, 107, 53, 0.8);
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: 'Press Start 2P', cursive;
				background: var(--color-background);
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				position: relative;
				overflow-x: hidden;
			}

			/* CRT Scanline Effect */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: repeating-linear-gradient(
					0deg,
					rgba(0, 0, 0, 0.15) 0px,
					rgba(0, 0, 0, 0.15) 1px,
					transparent 1px,
					transparent 2px
				);
				pointer-events: none;
				z-index: 9999;
				animation: scanline 8s linear infinite;
			}

			@keyframes scanline {
				0% {
					transform: translateY(0);
				}
				100% {
					transform: translateY(10px);
				}
			}

			main {
				background: rgba(10, 10, 26, 0.85);
				border: 3px solid var(--color-primary);
				box-shadow: 
					0 0 20px var(--color-glow-primary),
					inset 0 0 30px rgba(0, 0, 0, 0.5);
				padding: 40px;
				max-width: 700px;
				width: 100%;
				position: relative;
			}

			h1 {
				text-align: center;
				color: var(--color-primary);
				font-size: 2rem;
				margin-bottom: 10px;
				text-shadow:
					0 0 5px var(--color-primary),
					0 0 10px var(--color-primary),
					0 0 20px var(--color-primary),
					0 0 40px var(--color-primary),
					0 0 80px var(--color-primary);
				animation: neonPulse 2s ease-in-out infinite;
				letter-spacing: 2px;
			}

			@keyframes neonPulse {
				0%, 100% {
					text-shadow:
						0 0 5px var(--color-primary),
						0 0 10px var(--color-primary),
						0 0 20px var(--color-primary),
						0 0 40px var(--color-primary),
						0 0 80px var(--color-primary);
				}
				50% {
					text-shadow:
						0 0 2px var(--color-primary),
						0 0 5px var(--color-primary),
						0 0 10px var(--color-primary),
						0 0 20px var(--color-primary),
						0 0 40px var(--color-primary);
				}
			}

			.subtitle {
				text-align: center;
				color: var(--color-secondary);
				margin-bottom: 40px;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-shadow:
					0 0 5px var(--color-secondary),
					0 0 10px var(--color-secondary);
			}

			.battle-form {
				display: flex;
				flex-direction: column;
				gap: 30px;
			}

			.input-group {
				display: flex;
				flex-direction: column;
				gap: 12px;
				opacity: 0;
				animation: floatIn 0.8s ease-out forwards;
			}

			.input-group:first-child {
				animation-delay: 0.2s;
			}

			.input-group:last-of-type {
				animation-delay: 0.4s;
			}

			@keyframes floatIn {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			label {
				font-weight: 600;
				color: var(--color-primary);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-shadow: 0 0 5px var(--color-primary);
			}

			input {
				padding: 16px;
				background: rgba(10, 10, 26, 0.8);
				border: 2px solid var(--color-primary);
				color: #e0e0e0;
				font-size: 0.8rem;
				font-family: 'Press Start 2P', cursive;
				transition: all 0.3s;
				box-shadow: 0 0 10px rgba(95, 237, 131, 0.3);
			}

			input::placeholder {
				color: rgba(224, 224, 224, 0.4);
			}

			input:focus {
				outline: none;
				border-color: var(--color-secondary);
				box-shadow: 
					0 0 15px rgba(255, 107, 53, 0.6),
					inset 0 0 10px rgba(255, 107, 53, 0.2);
			}

			.vs {
				text-align: center;
				font-weight: bold;
				font-size: 2rem;
				padding: 20px;
				background: linear-gradient(90deg, var(--color-primary), var(--color-secondary), var(--color-primary));
				background-size: 200% 100%;
				-webkit-background-clip: text;
				background-clip: text;
				-webkit-text-fill-color: transparent;
				animation: gradientShift 3s ease infinite;
				text-shadow: none;
				position: relative;
				letter-spacing: 4px;
			}

			.vs::before {
				content: 'VS';
				position: absolute;
				left: 50%;
				top: 50%;
				transform: translate(-50%, -50%);
				-webkit-text-fill-color: rgba(95, 237, 131, 0.3);
				filter: blur(10px);
				z-index: -1;
			}

			@keyframes gradientShift {
				0%, 100% {
					background-position: 0% 50%;
				}
				50% {
					background-position: 100% 50%;
				}
			}

			button {
				background: rgba(10, 10, 26, 0.9);
				color: var(--color-primary);
				border: 3px solid var(--color-primary);
				padding: 20px 40px;
				font-size: 1rem;
				font-weight: bold;
				font-family: 'Press Start 2P', cursive;
				cursor: pointer;
				transition: all 0.3s;
				margin-top: 20px;
				box-shadow: 
					0 0 15px var(--color-glow-primary),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
				text-shadow: 0 0 5px var(--color-primary);
				letter-spacing: 2px;
			}

			button:hover:not(:disabled) {
				transform: scale(1.05);
				box-shadow: 
					0 0 30px rgba(95, 237, 131, 0.8),
					inset 0 0 20px var(--color-primary);
				text-shadow: 
					0 0 5px var(--color-primary),
					0 0 10px var(--color-primary),
					0 0 20px var(--color-primary);
			}

			button:active:not(:disabled) {
				transform: scale(0.95);
			}

			button:disabled {
				opacity: 0.5;
				cursor: not-allowed;
			}

			.button-group {
				display: flex;
				gap: 15px;
				justify-content: center;
				margin-top: 20px;
				flex-wrap: wrap;
			}

			.clear-btn {
				background: rgba(10, 10, 26, 0.9);
				color: #ff6b6b;
				border: 3px solid #ff6b6b;
				text-shadow: 0 0 5px #ff6b6b;
				box-shadow: 
					0 0 15px rgba(255, 107, 107, 0.4),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
				transition: all 0.3s;
				flex: 0 1 auto;
			}

			.clear-btn:hover:not(:disabled) {
				transform: scale(1.05);
				box-shadow: 
					0 0 30px rgba(255, 107, 107, 0.7),
					inset 0 0 20px rgba(255, 107, 107, 0.2);
				text-shadow: 
					0 0 5px #ff6b6b,
					0 0 10px #ff6b6b,
					0 0 20px #ff6b6b;
			}

			.clear-btn:active:not(:disabled) {
				transform: scale(0.95);
			}

			.theme-btn {
				background: rgba(10, 10, 26, 0.9);
				color: var(--color-secondary);
				border: 3px solid var(--color-secondary);
				text-shadow: 0 0 5px var(--color-secondary);
				box-shadow: 
					0 0 15px rgba(255, 107, 53, 0.4),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
				transition: all 0.3s;
				flex: 0 1 auto;
				font-size: 0.65rem;
			}

			.theme-btn:hover:not(:disabled) {
				transform: scale(1.05);
				box-shadow: 
					0 0 30px var(--color-secondary),
					inset 0 0 20px var(--color-secondary);
				text-shadow: 
					0 0 5px var(--color-secondary),
					0 0 10px var(--color-secondary),
					0 0 20px var(--color-secondary);
			}

			.theme-btn:active:not(:disabled) {
				transform: scale(0.95);
			}

			.mute-btn {
				background: rgba(10, 10, 26, 0.9);
				color: var(--color-primary);
				border: 3px solid var(--color-primary);
				text-shadow: 0 0 5px var(--color-primary);
				box-shadow: 
					0 0 15px rgba(95, 237, 131, 0.4),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
				transition: all 0.3s;
				flex: 0 1 auto;
				font-size: 0.65rem;
			}

			.mute-btn:hover:not(:disabled) {
				transform: scale(1.05);
				box-shadow: 
					0 0 30px rgba(95, 237, 131, 0.7),
					inset 0 0 20px var(--color-primary);
				text-shadow: 
					0 0 5px var(--color-primary),
					0 0 10px var(--color-primary),
					0 0 20px var(--color-primary);
			}

			.mute-btn:active:not(:disabled) {
				transform: scale(0.95);
			}

			.mute-btn.muted {
				color: #ff6b6b;
				border-color: #ff6b6b;
				text-shadow: 0 0 5px #ff6b6b;
				box-shadow: 
					0 0 15px rgba(255, 107, 107, 0.4),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
			}

			.error {
				display: none;
				background: rgba(255, 0, 0, 0.1);
				color: #ff4444;
				padding: 16px;
				margin-top: 20px;
				border: 2px solid #ff4444;
				font-size: 0.7rem;
				line-height: 1.6;
				box-shadow: 0 0 15px rgba(255, 68, 68, 0.3);
			}

			.error.show {
				display: block;
			}

			.loading {
				display: none;
				text-align: center;
				margin-top: 30px;
				font-size: 1rem;
				color: var(--color-primary);
				animation: colorShift 2s ease-in-out infinite;
				text-shadow: 0 0 10px currentColor;
			}

			.loading.show {
				display: block;
			}

			@keyframes colorShift {
				0%, 100% {
					color: var(--color-primary);
				}
				50% {
					color: var(--color-secondary);
				}
			}

			.loading::after {
				content: '...';
				animation: dots 1.5s steps(4, end) infinite;
			}

			@keyframes dots {
				0%, 20% { content: '.'; }
				40% { content: '..'; }
				60%, 100% { content: '...'; }
			}

			.results {
				display: none;
				margin-top: 30px;
			}

			.results.show {
				display: block;
			}

			.results-container {
				display: flex;
				flex-direction: column;
				gap: 20px;
				align-items: stretch;
				position: relative;
			}

			.player-result {
				background: rgba(10, 10, 26, 0.6);
				padding: 20px;
				border: 2px solid var(--color-primary);
				position: relative;
				overflow: hidden;
				box-shadow: 0 0 15px var(--color-glow-primary);
				transition: all 0.4s ease;
				animation: slideIn 0.6s ease-out;
			}

			@keyframes slideIn {
				from {
					opacity: 0;
					transform: translateY(40px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			.player-result::before {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 200%;
				height: 200%;
				background: linear-gradient(
					90deg,
					transparent,
					rgba(255, 255, 255, 0.1),
					transparent
				);
				animation: shimmer 3s infinite;
			}

			@keyframes shimmer {
				0% {
					transform: translateX(-100%) translateY(-100%) rotate(45deg);
				}
				100% {
					transform: translateX(100%) translateY(100%) rotate(45deg);
				}
			}

			.player-result::after {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: linear-gradient(
					135deg,
					transparent 0%,
					rgba(95, 237, 131, 0.05) 50%,
					transparent 100%
				);
				pointer-events: none;
				opacity: 0;
			}

			.player-result.winner {
				border-color: var(--color-secondary);
				background: linear-gradient(135deg, rgba(255, 107, 53, 0.15), rgba(10, 10, 26, 0.9));
				box-shadow: 
					0 0 30px var(--color-glow-secondary),
					0 0 60px rgba(255, 107, 53, 0.5),
					inset 0 0 20px rgba(255, 107, 53, 0.2);
				animation: slideIn 0.6s ease-out, winnerGlow 2s ease-in-out infinite;
				transform: scale(1.02);
			}

			@keyframes winnerGlow {
				0%, 100% {
					box-shadow: 
						0 0 30px var(--color-glow-secondary),
						0 0 60px rgba(255, 107, 53, 0.5),
						inset 0 0 20px rgba(255, 107, 53, 0.2);
				}
				50% {
					box-shadow: 
						0 0 50px var(--color-secondary),
						0 0 100px rgba(255, 107, 53, 0.7),
						inset 0 0 30px rgba(255, 107, 53, 0.3);
				}
			}

			.player-result.winner::before {
				background: linear-gradient(
					90deg,
					transparent,
					rgba(255, 107, 53, 0.5),
					transparent
				);
				animation: shimmer 1.5s infinite;
			}

			.player-result.winner::after {
				animation: winnerFlash 0.8s ease-in-out infinite;
				opacity: 1;
			}

			@keyframes winnerFlash {
				0%, 100% {
					opacity: 0;
				}
				50% {
					opacity: 0.3;
				}
			}

			/* Player Header - Avatar + Info Side by Side */
			.player-header {
				display: flex;
				gap: 15px;
				align-items: center;
				margin-bottom: 15px;
				padding: 12px;
				background: rgba(95, 237, 131, 0.1);
				border-radius: 4px;
				border: 1px solid rgba(95, 237, 131, 0.3);
			}

			.player-result.winner .player-header {
				background: rgba(255, 107, 53, 0.15);
				border-color: rgba(255, 107, 53, 0.4);
			}

			.player-info {
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 8px;
			}

			.player-name {
				font-size: 0.9rem;
				font-weight: bold;
				color: var(--color-primary);
				text-shadow: 
					0 0 10px var(--color-primary),
					0 0 20px rgba(95, 237, 131, 0.6);
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 10px;
				animation: playerNameGlow 1.5s ease-in-out infinite;
			}

			.player-result.winner .player-name {
				color: #ff00ff;
				text-shadow: 
					0 0 10px #ff00ff,
					0 0 20px #ff00ff,
					0 0 30px rgba(255, 0, 255, 0.6);
				animation: nameGlow 1.5s ease-in-out infinite;
			}

			@keyframes playerNameGlow {
				0%, 100% {
					text-shadow: 
						0 0 10px var(--color-primary),
						0 0 20px rgba(95, 237, 131, 0.6);
				}
				50% {
					text-shadow: 
						0 0 15px var(--color-primary),
						0 0 30px rgba(95, 237, 131, 0.8);
				}
			}

			@keyframes nameGlow {
				0%, 100% {
					text-shadow: 
						0 0 10px #ff00ff,
						0 0 20px #ff00ff;
				}
				50% {
					text-shadow: 
						0 0 15px #ff00ff,
						0 0 30px #ff00ff;
				}
			}

			.player-stats {
				font-size: 0.6rem;
				color: var(--color-primary);
				background: rgba(0, 0, 0, 0.2);
				padding: 8px;
				border-left: 2px solid var(--color-primary);
				animation: statsSlideIn 0.8s ease-out;
			}

			@keyframes statsSlideIn {
				from {
					opacity: 0;
					transform: translateX(-20px);
				}
				to {
					opacity: 1;
					transform: translateX(0);
				}
			}

			.player-result.winner .player-stats {
				background: rgba(255, 107, 53, 0.2);
				border-left-color: var(--color-secondary);
				color: var(--color-light-accent);
				box-shadow: 0 0 10px rgba(255, 107, 53, 0.2);
			}

			.stat-row {
				display: flex;
				justify-content: space-between;
				margin-bottom: 4px;
				gap: 8px;
			}

			.stat-label {
				font-weight: 600;
				color: var(--color-primary);
				text-shadow: 0 0 8px rgba(95, 237, 131, 0.6);
				flex: 0 0 auto;
			}

			.player-result.winner .stat-label {
				color: var(--color-light-accent);
				text-shadow: 0 0 8px rgba(255, 107, 53, 0.8);
			}

			.stat-value {
				color: var(--color-secondary);
				font-weight: bold;
				text-shadow: 
					0 0 8px var(--color-secondary),
					0 0 15px rgba(138, 43, 226, 0.6);
				animation: valueGlow 1.5s ease-in-out infinite;
				flex: 1;
				text-align: right;
			}

			.player-result.winner .stat-value {
				color: #ff00ff;
				text-shadow: 
					0 0 8px #ff00ff,
					0 0 15px rgba(255, 107, 53, 0.8);
				animation: winnerValueGlow 1s ease-in-out infinite;
			}

			@keyframes valueGlow {
				0%, 100% {
					text-shadow: 0 0 5px #8a2be2;
				}
				50% {
					text-shadow: 0 0 15px #8a2be2;
				}
			}

			@keyframes winnerValueGlow {
				0%, 100% {
					text-shadow: 
						0 0 8px #ff00ff,
						0 0 15px rgba(255, 107, 53, 0.8);
				}
				50% {
					text-shadow: 
						0 0 12px #ff00ff,
						0 0 25px rgba(255, 107, 53, 1);
				}
			}

			.contribution-graph-label {
				font-size: 0.7rem;
				font-weight: 600;
				color: var(--color-secondary);
				margin-bottom: 10px;
				text-transform: uppercase;
				letter-spacing: 0.5px;
				text-shadow: 0 0 10px rgba(138, 43, 226, 0.6);
				animation: labelPulse 2s ease-in-out infinite;
			}

			@keyframes labelPulse {
				0%, 100% {
					color: var(--color-secondary);
