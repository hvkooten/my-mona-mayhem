		</style>

		<script>
			const player1Input = document.getElementById('player1') as HTMLInputElement;
			const player2Input = document.getElementById('player2') as HTMLInputElement;
			const battleBtn = document.getElementById('battleBtn') as HTMLButtonElement;
			const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
			const themeBtn = document.getElementById('themeBtn') as HTMLButtonElement;
			const muteBtn = document.getElementById('muteBtn') as HTMLButtonElement;
			const errorDiv = document.getElementById('error') as HTMLDivElement;
			const loadingDiv = document.getElementById('loading') as HTMLDivElement;
			const resultsDiv = document.getElementById('results') as HTMLDivElement;

			// LocalStorage keys for saving usernames
			const STORAGE_KEY_PLAYER1 = 'mona-mayhem-player1';
			const STORAGE_KEY_PLAYER2 = 'mona-mayhem-player2';
			const STORAGE_KEY_SOUND = 'mona-mayhem-sound-enabled';
			const STORAGE_KEY_THEME = 'mona-mayhem-theme';

			/**
			 * Web Audio API Sound Manager
			 * Generates retro arcade sounds using oscillators and gain nodes
			 */
			class SoundManager {
				private audioContext: AudioContext | null = null;
				private isMuted: boolean = false;

				constructor() {
					this.isMuted = localStorage.getItem(STORAGE_KEY_SOUND) === 'false';
					this.updateMuteButton();
				}

				private getAudioContext(): AudioContext {
					if (!this.audioContext) {
						this.audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
					}
					return this.audioContext;
				}

				/**
				 * Plays a coin insert sound (classic arcade)
				 * Two ascending tones mimicking a coin drop
				 */
				playCoin() {
					if (this.isMuted) return;
					const ctx = this.getAudioContext();
					const now = ctx.currentTime;

					// First tone (higher)
					const osc1 = ctx.createOscillator();
					const gain1 = ctx.createGain();
					osc1.connect(gain1);
					gain1.connect(ctx.destination);
					osc1.frequency.value = 1000;
					osc1.type = 'sine';
					gain1.gain.setValueAtTime(0.3, now);
					gain1.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
					osc1.start(now);
					osc1.stop(now + 0.1);

					// Second tone (lower)
					const osc2 = ctx.createOscillator();
					const gain2 = ctx.createGain();
					osc2.connect(gain2);
					gain2.connect(ctx.destination);
					osc2.frequency.value = 800;
					osc2.type = 'sine';
					gain2.gain.setValueAtTime(0.3, now + 0.15);
					gain2.gain.exponentialRampToValueAtTime(0.01, now + 0.25);
					osc2.start(now + 0.15);
					osc2.stop(now + 0.25);
				}

				/**
				 * Plays a power-up sound (classic video game power-up)
				 * Rising pitch with harmonic overtones
				 */
				playPowerUp() {
					if (this.isMuted) return;
					const ctx = this.getAudioContext();
					const now = ctx.currentTime;

					// Main oscillator - rising pitch
					const osc = ctx.createOscillator();
					const gain = ctx.createGain();
					osc.connect(gain);
					gain.connect(ctx.destination);
					osc.type = 'square';
					osc.frequency.setValueAtTime(400, now);
					osc.frequency.exponentialRampToValueAtTime(800, now + 0.1);
					osc.frequency.exponentialRampToValueAtTime(1200, now + 0.2);
					gain.gain.setValueAtTime(0.2, now);
					gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
					osc.start(now);
					osc.stop(now + 0.2);

					// Harmonic overtone for richness
					const osc2 = ctx.createOscillator();
					const gain2 = ctx.createGain();
					osc2.connect(gain2);
					gain2.connect(ctx.destination);
					osc2.type = 'sine';
					osc2.frequency.setValueAtTime(1200, now);
					osc2.frequency.exponentialRampToValueAtTime(2400, now + 0.1);
					osc2.frequency.exponentialRampToValueAtTime(3600, now + 0.2);
					gain2.gain.setValueAtTime(0.1, now);
					gain2.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
					osc2.start(now);
					osc2.stop(now + 0.2);
				}

				/**
				 * Plays an explosion sound (error notification)
				 * Sharp burst with frequency drop and noise
				 */
				playExplosion() {
					if (this.isMuted) return;
					const ctx = this.getAudioContext();
					const now = ctx.currentTime;

					// Create noise buffer for explosion effect
					const bufferSize = ctx.sampleRate * 0.2;
					const noiseBuffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
					const output = noiseBuffer.getChannelData(0);
					for (let i = 0; i < bufferSize; i++) {
						output[i] = Math.random() * 2 - 1;
					}
					const noiseSource = ctx.createBufferSource();
					noiseSource.buffer = noiseBuffer;
					const noiseGain = ctx.createGain();
					noiseSource.connect(noiseGain);
					noiseGain.connect(ctx.destination);
					noiseGain.gain.setValueAtTime(0.3, now);
					noiseGain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
					noiseSource.start(now);

					// Explosion tone (pitch drop)
					const osc = ctx.createOscillator();
					const oscGain = ctx.createGain();
					osc.connect(oscGain);
					oscGain.connect(ctx.destination);
					osc.type = 'sine';
					osc.frequency.setValueAtTime(150, now);
					osc.frequency.exponentialRampToValueAtTime(50, now + 0.1);
					osc.frequency.exponentialRampToValueAtTime(20, now + 0.2);
					oscGain.gain.setValueAtTime(0.2, now);
					oscGain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
					osc.start(now);
					osc.stop(now + 0.2);
				}

				/**
				 * Plays a countdown beep sound (for battle countdown)
				 * Short, punchy beep at varying frequencies
				 */
				playBeep(frequency: number = 800, duration: number = 0.15) {
					if (this.isMuted) return;
					const ctx = this.getAudioContext();
					const now = ctx.currentTime;

					const osc = ctx.createOscillator();
					const gain = ctx.createGain();
					osc.connect(gain);
					gain.connect(ctx.destination);
					osc.type = 'square';
					osc.frequency.value = frequency;
					gain.gain.setValueAtTime(0.3, now);
					gain.gain.exponentialRampToValueAtTime(0.01, now + duration);
					osc.start(now);
					osc.stop(now + duration);
				}

				/**
				 * Plays a "FIGHT!" sound - loud, punchy explosion-like sound
				 */
				playFight() {
					if (this.isMuted) return;
					const ctx = this.getAudioContext();
					const now = ctx.currentTime;

					// Create noise buffer for the "hit" sound
					const bufferSize = ctx.sampleRate * 0.3;
					const noiseBuffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
					const output = noiseBuffer.getChannelData(0);
					for (let i = 0; i < bufferSize; i++) {
						output[i] = Math.random() * 2 - 1;
					}
					const noiseSource = ctx.createBufferSource();
					noiseSource.buffer = noiseBuffer;
					const noiseGain = ctx.createGain();
					noiseSource.connect(noiseGain);
					noiseGain.connect(ctx.destination);
					noiseGain.gain.setValueAtTime(0.4, now);
					noiseGain.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
					noiseSource.start(now);

					// Low frequency punch
					const osc = ctx.createOscillator();
					const oscGain = ctx.createGain();
					osc.connect(oscGain);
					oscGain.connect(ctx.destination);
					osc.type = 'sine';
					osc.frequency.setValueAtTime(200, now);
					osc.frequency.exponentialRampToValueAtTime(100, now + 0.3);
					oscGain.gain.setValueAtTime(0.3, now);
					oscGain.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
					osc.start(now);
					osc.stop(now + 0.3);
				}

				/**
				 * Toggle mute state
				 */
				toggleMute() {
					this.isMuted = !this.isMuted;
					localStorage.setItem(STORAGE_KEY_SOUND, this.isMuted ? 'false' : 'true');
					this.updateMuteButton();
				}

				/**
				 * Update mute button appearance
				 */
				private updateMuteButton() {
					if (this.isMuted) {
						muteBtn.classList.add('muted');
						muteBtn.textContent = '🔇 MUTED';
					} else {
						muteBtn.classList.remove('muted');
						muteBtn.textContent = '🔊 SOUND';
					}
				}
			}

			const soundManager = new SoundManager();

			/**
			 * Theme Manager - Handles toggling between color themes
			 * Stores preference in localStorage and updates the root element class
			 */
			class ThemeManager {
				private currentTheme: string = 'default';

				constructor() {
					this.currentTheme = localStorage.getItem(STORAGE_KEY_THEME) || 'default';
					this.applyTheme(this.currentTheme);
				}

				private applyTheme(theme: string) {
					if (theme === 'blue-orange') {
						document.documentElement.classList.add('theme-blue-orange');
					} else {
						document.documentElement.classList.remove('theme-blue-orange');
					}
					this.currentTheme = theme;
				}

				public toggleTheme() {
					const newTheme = this.currentTheme === 'default' ? 'blue-orange' : 'default';
					this.applyTheme(newTheme);
					localStorage.setItem(STORAGE_KEY_THEME, newTheme);
				}

				public getCurrentTheme(): string {
					return this.currentTheme;
				}
			}

			const themeManager = new ThemeManager();

			/**
			 * Represents a single day's contribution data in GitHub's contribution graph.
			 * GitHub provides contribution data with levels 0-4 indicating intensity.
			 * 
			 * @interface ContributionDay
			 * @property {number} weekday - Day of week (0 = Sunday, 6 = Saturday)
			 * @property {number} count - Total contributions on this day
			 * @property {number} level - Contribution intensity level (0-4)
			 *   0 = none, 1 = low, 2 = medium, 3 = high, 4 = very high
			 */
			interface ContributionDay {
				weekday: number;
				count: number;
				level: number;
			}

			/**
			 * Represents a week of contribution data (7 days).
			 * 
			 * @interface ContributionWeek
			 * @property {number} index - Week index in the response
			 * @property {string} first_day - First day of the week (YYYY-MM-DD format)
			 * @property {ContributionDay[]} contribution_days - Array of 7 contribution day objects
			 */
			interface ContributionWeek {
				index: number;
				first_day: string;
				contribution_days: ContributionDay[];
			}

			/**
			 * Full contribution data response from GitHub API (v2 format).
			 * This is the complete structure returned by https://github.com/{username}.contribs
			 * 
			 * @interface ContributionData
			 * @property {string} schema - API version (e.g., "v2")
			 * @property {string} generated_at - ISO timestamp when data was generated
			 * @property {string} from - Start date of contribution range (YYYY-MM-DD)
			 * @property {string} to - End date of contribution range (YYYY-MM-DD)
			 * @property {number} range_days - Total days in the range
			 * @property {number} total_contributions - Sum of all contributions in range
			 * @property {boolean} private_contributions_included - Whether private repos are counted
			 * @property {string[]} colors_full - Hex color palette for visualization
			 * @property {ContributionWeek[]} weeks - Array of weeks with daily contribution data
			 * @property {Array} months - Month metadata
			 */
			interface ContributionData {
				schema: string;
				generated_at: string;
				from: string;
				to: string;
				range_days: number;
				total_contributions: number;
				private_contributions_included: boolean;
				colors_full: string[];
				weeks: ContributionWeek[];
				months: Array<{
					month: string;
					total_weeks: number;
				}>;
			}

			/**
			 * Player data used during battle comparison.
			 * Wraps contribution data with calculated totals and date ranges.
			 * 
			 * @interface PlayerData
			 * @property {string} username - GitHub username
			 * @property {number} totalContributions - Total contributions in range
			 * @property {ContributionData} data - Full API response object
			 * @property {Object} dateRange - Extracted date range
			 * @property {string} dateRange.start - Start date (YYYY-MM-DD)
			 * @property {string} dateRange.end - End date (YYYY-MM-DD)
			 */
			interface PlayerData {
				username: string;
				totalContributions: number;
				data: ContributionData;
				dateRange: {
					start: string;
					end: string;
				};
			}

			// GitHub contribution color palette (based on levels 0-4)
			// Maps contribution levels to hex colors matching GitHub's official palette
			// Level 0: No contributions (light gray)
			// Level 1-2: Light to medium activity (green shades)
			// Level 3-4: High activity (darker green shades)
			const CONTRIBUTION_COLORS: Record<number, string> = {
				0: '#ebedf0',  // No contributions
				1: '#c6e48b',  // Low activity
				2: '#40c463',  // Medium activity
				3: '#30a14e',  // High activity
				4: '#216e39'   // Very high activity
			};

			function showError(message) {
				errorDiv.textContent = message;
				errorDiv.classList.add('show');
				soundManager.playExplosion();
			}

			function hideError() {
				errorDiv.textContent = '';
				errorDiv.classList.remove('show');
			}

			function showLoading(message = 'Fetching battle data') {
				loadingDiv.textContent = message;
				loadingDiv.classList.add('show');
			}

			function hideLoading() {
				loadingDiv.textContent = '';
				loadingDiv.classList.remove('show');
			}

			/**
			 * Clears all result data from the results container and hides it.
			 * Called before starting a new battle to ensure clean state.
			 */
			function hideResults() {
				resultsDiv.innerHTML = '';
				resultsDiv.classList.remove('show');
			}

			/**
			 * Fetches a user's contribution data from the server API.
			 * The API proxy handles GitHub rate limiting and CORS.
			 * Contributions are cached server-side for 5 minutes.
			 * 
			 * @async
			 * @param {string} username - GitHub username to fetch data for
			 * @returns {Promise<ContributionData>} The contribution data or throws on error
			 * @throws {Error} If username is not found or API returns error
			 * 
			 * @example
			 * const data = await fetchContributions('torvalds');
			 * console.log(data.total_contributions); // 2986
			 */
			async function fetchContributions(username: string): Promise<ContributionData> {
				const response = await fetch(`/api/contributions/${username}`);
				
				if (!response.ok) {
					const error = await response.json();
					throw new Error(error.error || `Failed to fetch data for ${username}`);
				}

				return await response.json();
			}

			/**
			 * Calculates the total contribution count from contribution data.
			 * Safely extracts the total_contributions field with null-checks.
			 * 
			 * @param {ContributionData} data - Contribution data object
			 * @returns {number} Total contributions, or 0 if data is invalid
			 * 
			 * @example
			 * const total = calculateTotalContributions(data);
			 * console.log(total.toLocaleString()); // "2,986"
			 */
			function calculateTotalContributions(data: ContributionData): number {
				if (!data || typeof data.total_contributions !== 'number') {
					console.error('Invalid contribution data structure:', data);
					return 0;
				}
				return data.total_contributions;
			}

			/**
			 * Generates HTML for a contribution graph grid visualization.
			 * Creates a week-by-week grid where each day is a colored square based on contribution level.
			 * Uses GitHub's official color palette (levels 0-4 map to specific hex colors).
			 * 
			 * @param {ContributionData} data - Contribution data with weeks array
			 * @param {string} username - Username (for debugging, not used in output)
			 * @returns {string} HTML string containing the contribution grid, or placeholder message
			 * 
			 * @example
			 * const html = renderContributionGrid(data, 'torvalds');
			 * // Returns: '<div class="contribution-grid">...'
			 */
			function renderContributionGrid(data: ContributionData, username: string): string {
				if (!data || !Array.isArray(data.weeks) || data.weeks.length === 0) {
					return '<div class="grid-placeholder">No contribution data available</div>';
				}

				// Create grid HTML from weeks
				const weeksHTML = data.weeks.map(week => {
					if (!week || !Array.isArray(week.contribution_days)) {
						return '<div class="contribution-week"></div>';
					}
					const daysHTML = week.contribution_days.map(day => {
						if (!day) return '';
						const level = day.level || 0;
						const color = CONTRIBUTION_COLORS[level] || '#ebedf0';
						const dayName = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][day.weekday];
						return `<div class="contribution-day" style="background-color: ${color};" title="${dayName}: ${day.count} contributions"></div>`;
					}).join('');
					return `<div class="contribution-week">${daysHTML}</div>`;
				}).join('');

				return `<div class="contribution-grid">${weeksHTML}</div>`;
			}

			/**
			 * Extracts the date range from contribution data.
			 * Returns the 'from' and 'to' dates from the API response.
			 * 
			 * @param {ContributionData} data - Contribution data object
			 * @returns {Object} Date range object with start and end dates (YYYY-MM-DD format)
			 * @returns {string} .start - Start date
			 * @returns {string} .end - End date
			 * 
			 * @example
			 * const range = getDateRange(data);
			 * console.log(range); // { start: '2025-04-13', end: '2026-04-15' }
			 */
			function getDateRange(data: ContributionData): { start: string; end: string } {
				if (!data) {
					return { start: 'N/A', end: 'N/A' };
				}
				return {
					start: data.from || 'N/A',
					end: data.to || 'N/A'
				};
			}

			/**
			 * Renders the battle comparison results showing both players' data.
			 * Displays contribution graphs, totals, date ranges, and determines the winner.
			 * Winner is determined by total_contributions count.
			 * 
			 * @param {PlayerData} player1 - First player's data
			 * @param {PlayerData} player2 - Second player's data
			 * 
			 * @example
			 * displayResults(player1Data, player2Data);
			 * // Renders HTML with both players' info, graphs, and winner announcement
			 */

			// Confetti animation
			function createConfetti() {
				const canvas = document.getElementById('confettiCanvas') as HTMLCanvasElement;
				const ctx = canvas.getContext('2d')!;
				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;

				const confettiPieces: any[] = [];
				const colors = ['#ffd700', '#5fed83', '#8a2be2', '#ff6b6b', '#4ecdc4', '#ffe66d'];
				
				for (let i = 0; i < 150; i++) {
					confettiPieces.push({
						x: Math.random() * canvas.width,
						y: Math.random() * canvas.height - canvas.height,
						w: Math.random() * 10 + 5,
						h: Math.random() * 10 + 5,
						color: colors[Math.floor(Math.random() * colors.length)],
						rotation: Math.random() * 360,
						rotationSpeed: Math.random() * 10 - 5,
						speedX: Math.random() * 3 - 1.5,
						speedY: Math.random() * 3 + 2
					});
				}

				function animate() {
					ctx.clearRect(0, 0, canvas.width, canvas.height);
					
					confettiPieces.forEach(piece => {
						ctx.save();
						ctx.translate(piece.x + piece.w / 2, piece.y + piece.h / 2);
						ctx.rotate(piece.rotation * Math.PI / 180);
						ctx.fillStyle = piece.color;
						ctx.fillRect(-piece.w / 2, -piece.h / 2, piece.w, piece.h);
						ctx.restore();
						
						piece.y += piece.speedY;
						piece.x += piece.speedX;
						piece.rotation += piece.rotationSpeed;
						
						if (piece.y > canvas.height) {
							piece.y = -20;
							piece.x = Math.random() * canvas.width;
						}
					});
					
					requestAnimationFrame(animate);
				}
				
				animate();
			}

			// Battle animation sequence
			function playBattleAnimation(winner: PlayerData, loser: PlayerData) {
				const overlay = document.getElementById('battleOverlay')!;
				const player1NameDiv = document.getElementById('player1Name')!;
				const player2NameDiv = document.getElementById('player2Name')!;
				const pacman = document.getElementById('pacman')!;
				const canvas = document.getElementById('confettiCanvas') as HTMLCanvasElement;

				// Show overlay
				overlay.classList.add('active');

				// Set player names
				player1NameDiv.textContent = loser.username;
				player2NameDiv.textContent = winner.username;

				// Show names with animation
				setTimeout(() => {
					player1NameDiv.classList.add('show');
					player2NameDiv.classList.add('show');
				}, 100);

				// After 5 seconds, start Pac-Man sequence
				setTimeout(() => {
					// Position Pac-Man
					const loserRect = player1NameDiv.getBoundingClientRect();
					pacman.style.left = (loserRect.left - 150) + 'px';
					pacman.style.top = (loserRect.top + loserRect.height / 2 - 50) + 'px';
					pacman.classList.add('active');

					// Animate Pac-Man to loser
					let currentX = loserRect.left - 150;
					const targetX = loserRect.left - 30;
					const speed = 5;

					const movePacman = setInterval(() => {
						currentX += speed;
						pacman.style.left = currentX + 'px';

						if (currentX >= targetX) {
							clearInterval(movePacman);
							
							// Start eating animation
							player1NameDiv.classList.add('eaten');
							
							// After eating, grow winner and start confetti
							setTimeout(() => {
								player2NameDiv.classList.add('winner-grow');
								createConfetti();
								
								// Hide overlay after 5 more seconds
								setTimeout(() => {
									overlay.classList.remove('active');
									player1NameDiv.classList.remove('show', 'eaten');
									player2NameDiv.classList.remove('show', 'winner-grow');
									pacman.classList.remove('active');
									
									// Clear canvas
									const ctx = canvas.getContext('2d')!;
									ctx.clearRect(0, 0, canvas.width, canvas.height);
								}, 5000);
							}, 800);
						}
					}, 30);
				}, 5000);
			}

			/**
			 * Fetch GitHub user avatar URL
			 * @param username GitHub username
			 * @returns Avatar URL from GitHub API
			 */
			async function getGitHubAvatar(username: string): Promise<string> {
				try {
					// Use GitHub's avatar URL directly - more reliable than API
					const avatarUrl = `https://github.com/${username}.png`;
					
					// Verify the image exists with a HEAD request
					const response = await fetch(avatarUrl, { method: 'HEAD' });
					if (response.ok) {
						return avatarUrl;
					}
					
					// Fallback to API if direct URL fails
					const apiResponse = await fetch(`https://api.github.com/users/${username}`, {
						headers: {
							'Accept': 'application/vnd.github.v3+json'
						}
					});
					
					if (apiResponse.ok) {
						const data = await apiResponse.json();
						return data.avatar_url || '';
					}
					
					return '';
				} catch (error) {
					console.warn(`Could not fetch avatar for ${username}:`, error);
					return '';
				}
			}

			/**
			 * Play countdown animation with beeps
			 * Shows 3, 2, 1, FIGHT! with 1 second each
			 * @param onComplete Callback when countdown finishes
			 */
			async function playCountdown(onComplete: () => void) {
				const overlay = document.getElementById('battleOverlay')!;
				const countdownOverlay = document.getElementById('countdownOverlay')!;
				const countdownText = document.getElementById('countdownText')!;

				overlay.classList.add('active');
				countdownOverlay.classList.add('active');

				const countdownSequence = [
					{ text: '3', frequency: 600, delay: 0 },
					{ text: '2', frequency: 800, delay: 1000 },
					{ text: '1', frequency: 1000, delay: 2000 }
				];

				// Play countdown beeps
				for (const step of countdownSequence) {
					await new Promise(resolve => setTimeout(resolve, step.delay));
					countdownText.textContent = step.text;
					soundManager.playBeep(step.frequency, 0.15);
				}

				// Play FIGHT! sound and show it
				await new Promise(resolve => setTimeout(resolve, 1000));
				countdownText.textContent = '⚡ FIGHT! ⚡';
				countdownText.style.animation = 'fightPulse 1s ease-in-out forwards';
				soundManager.playFight();

				// Wait for FIGHT animation to complete
				await new Promise(resolve => setTimeout(resolve, 1000));

				// Hide countdown overlay
				countdownOverlay.classList.remove('active');
				countdownText.style.animation = 'countdownPulse 1s ease-in-out forwards';
				overlay.classList.remove('active');

				onComplete();
			}

			function displayResults(player1: PlayerData, player2: PlayerData) {
				const isPlayer1Winner = player1.totalContributions > player2.totalContributions;
				const isPlayer2Winner = player2.totalContributions > player1.totalContributions;
				const isTie = player1.totalContributions === player2.totalContributions;

				const player1Grid = renderContributionGrid(player1.data, player1.username);
				const player2Grid = renderContributionGrid(player2.data, player2.username);

				// Fetch avatars for both players
				Promise.all([
					getGitHubAvatar(player1.username),
					getGitHubAvatar(player2.username)
				]).then(([avatar1, avatar2]) => {
					const avatar1Html = avatar1 ? `<img src="${avatar1}" alt="${player1.username}" class="player-avatar" onerror="this.style.display='none'" />` : '';
					const avatar2Html = avatar2 ? `<img src="${avatar2}" alt="${player2.username}" class="player-avatar" onerror="this.style.display='none'" />` : '';

					resultsDiv.innerHTML = `
						<div class="results-container">
							<div class="player-result ${isPlayer1Winner ? 'winner' : ''}">
								<div class="player-header">
									${avatar1Html}
									<div class="player-info">
										<div class="player-name">
											${player1.username}
											${isPlayer1Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
										</div>
										<div class="player-stats">
											<div class="stat-row">
												<span class="stat-label">Total:</span>
												<span class="stat-value">${player1.totalContributions.toLocaleString()}</span>
											</div>
											<div class="stat-row">
												<span class="stat-label">Period:</span>
												<span class="stat-value">${player1.dateRange.start}</span>
											</div>
										</div>
									</div>
								</div>
								<div class="contribution-graph-label">Last Year Activity</div>
								${player1Grid}
							</div>

							<div class="vs-badge">VS</div>

							<div class="player-result ${isPlayer2Winner ? 'winner' : ''}">
								<div class="player-header">
									${avatar2Html}
									<div class="player-info">
										<div class="player-name">
											${player2.username}
											${isPlayer2Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
										</div>
										<div class="player-stats">
											<div class="stat-row">
												<span class="stat-label">Total:</span>
												<span class="stat-value">${player2.totalContributions.toLocaleString()}</span>
											</div>
											<div class="stat-row">
												<span class="stat-label">Period:</span>
												<span class="stat-value">${player2.dateRange.start}</span>
											</div>
										</div>
									</div>
								</div>
								<div class="contribution-graph-label">Last Year Activity</div>
								${player2Grid}
							</div>

							<div class="battle-summary">
								${isTie ? '🤝 It\'s a tie!' : 
									isPlayer1Winner ? `🎉 ${player1.username} wins with ${(player1.totalContributions - player2.totalContributions).toLocaleString()} more contributions!` : 
									`🎉 ${player2.username} wins with ${(player2.totalContributions - player1.totalContributions).toLocaleString()} more contributions!`}
							</div>
						</div>
					`;

					resultsDiv.classList.add('show');
					soundManager.playPowerUp();

					// Play battle animation
					const winner = isPlayer1Winner ? player1 : player2;
					const loser = isPlayer1Winner ? player2 : player1;
					
					if (!isTie) {
						playBattleAnimation(winner, loser);
					}
				});
			}

			/**
			 * Main battle orchestration function. Handles the complete battle flow:
			 * 1. Validates both input fields are filled
			 * 2. Shows loading state
			 * 3. Fetches both users' data in parallel
			 * 4. Calculates statistics (totals, date ranges)
			 * 5. Renders comparison results with winner determination
			 * 6. Handles errors and cleans up loading state
			 * 
			 * Called when:
			 * - Battle button is clicked
			 * - Enter key is pressed in either input field
			 * 
			 * @async
			 * @returns {Promise<void>}
			 * 
			 * Flow visualization:
			 * Validate inputs
			 *   ↓
			 * Show loading + disable button
			 *   ↓
			 * Fetch data in parallel (Promise.all)
			 *   ↓
			 * Validate responses
			 *   ↓
			 * Calculate stats (totals, dates)
			 *   ↓
			 * Display results + determine winner
			 *   ↓
			 * Hide loading + enable button
			 */
			async function handleBattle() {
				const username1 = player1Input.value.trim();
				const username2 = player2Input.value.trim();

				hideError();
				hideResults();
				soundManager.playCoin();

				// Validate inputs
				if (!username1 || !username2) {
					showError('Please enter both usernames');
					return;
				}

				// Disable button and show loading
				battleBtn.disabled = true;
				showLoading();

				try {
					// Fetch both users' data in parallel
					const [data1, data2] = await Promise.all([
						fetchContributions(username1),
						fetchContributions(username2)
					]);

					// Validate data structure
					if (!data1 || typeof data1 !== 'object') {
						throw new Error(`Invalid data received for user ${username1}`);
					}
					if (!data2 || typeof data2 !== 'object') {
						throw new Error(`Invalid data received for user ${username2}`);
					}

					// Calculate totals and date ranges
					const dateRange1 = getDateRange(data1);
					const dateRange2 = getDateRange(data2);

					const player1Data = {
						username: username1,
						totalContributions: calculateTotalContributions(data1),
						data: data1,
						dateRange: dateRange1
					};

					const player2Data = {
						username: username2,
						totalContributions: calculateTotalContributions(data2),
						data: data2,
						dateRange: dateRange2
					};

					// Hide loading before countdown
					hideLoading();

					// Play countdown then display results
					playCountdown(() => {
						displayResults(player1Data, player2Data);
					});

				} catch (error) {
					console.error('Battle error:', error);
					showError(error instanceof Error ? error.message : 'An error occurred during the battle');
					hideLoading();
				} finally {
					battleBtn.disabled = false;
				}
			}

			// Attach event listener
			battleBtn.addEventListener('click', handleBattle);

			// Clear button functionality
			clearBtn.addEventListener('click', () => {
				player1Input.value = '';
				player2Input.value = '';
				localStorage.removeItem(STORAGE_KEY_PLAYER1);
				localStorage.removeItem(STORAGE_KEY_PLAYER2);
				hideError();
				hideResults();
			});

			// Mute button functionality
			muteBtn.addEventListener('click', () => {
				soundManager.toggleMute();
			});

			// Theme button functionality
			themeBtn.addEventListener('click', () => {
				themeManager.toggleTheme();
			});

			// Save usernames to localStorage when they change
			player1Input.addEventListener('input', (e) => {
				const value = (e.target as HTMLInputElement).value;
				if (value) {
					localStorage.setItem(STORAGE_KEY_PLAYER1, value);
				} else {
					localStorage.removeItem(STORAGE_KEY_PLAYER1);
				}
			});

			player2Input.addEventListener('input', (e) => {
				const value = (e.target as HTMLInputElement).value;
				if (value) {
					localStorage.setItem(STORAGE_KEY_PLAYER2, value);
				} else {
					localStorage.removeItem(STORAGE_KEY_PLAYER2);
				}
			});

			// Load saved usernames on page load
			window.addEventListener('load', () => {
				const savedPlayer1 = localStorage.getItem(STORAGE_KEY_PLAYER1);
				const savedPlayer2 = localStorage.getItem(STORAGE_KEY_PLAYER2);
				
				if (savedPlayer1) {
					player1Input.value = savedPlayer1;
				}
				if (savedPlayer2) {
					player2Input.value = savedPlayer2;
				}
			});

			// Allow Enter key in inputs
			[player1Input, player2Input].forEach(input => {
				input.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') {
						handleBattle();
					}
				});
			});
		</script>
	</body>
</html>
