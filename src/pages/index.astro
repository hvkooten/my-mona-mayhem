			.error.show {
				display: block;
			}

			.loading {
				display: none;
				text-align: center;
				margin-top: 30px;
				font-size: 1rem;
				color: #5fed83;
				animation: colorShift 2s ease-in-out infinite;
				text-shadow: 0 0 10px currentColor;
			}

			.loading.show {
				display: block;
			}

			@keyframes colorShift {
				0%, 100% {
					color: #5fed83;
				}
				50% {
					color: #8a2be2;
				}
			}

			.loading::after {
				content: '...';
				animation: dots 1.5s steps(4, end) infinite;
			}

			@keyframes dots {
				0%, 20% { content: '.'; }
				40% { content: '..'; }
				60%, 100% { content: '...'; }
			}

			.results {
				display: none;
				margin-top: 30px;
			}

			.results.show {
				display: block;
			}

			.results-container {
				display: flex;
				flex-direction: column;
				gap: 20px;
				align-items: stretch;
				position: relative;
			}

			.player-result {
				background: rgba(10, 10, 26, 0.6);
				padding: 20px;
				border: 2px solid #5fed83;
				position: relative;
				overflow: hidden;
				box-shadow: 0 0 15px rgba(95, 237, 131, 0.3);
			}

			.player-result::before {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 200%;
				height: 200%;
				background: linear-gradient(
					90deg,
					transparent,
					rgba(255, 255, 255, 0.1),
					transparent
				);
				animation: shimmer 3s infinite;
			}

			@keyframes shimmer {
				0% {
					transform: translateX(-100%) translateY(-100%) rotate(45deg);
				}
