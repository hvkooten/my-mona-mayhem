---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
	</head>
	<body>
		<main>
			<h1>🎮 Mona Mayhem</h1>
			<p class="subtitle">GitHub Contribution Battle Arena</p>

			<div class="battle-form">
				<div class="input-group">
					<label for="player1">Player 1</label>
					<input 
						type="text" 
						id="player1" 
						name="player1" 
						placeholder="Enter GitHub username"
						autocomplete="off"
					/>
				</div>

				<div class="vs">VS</div>

				<div class="input-group">
					<label for="player2">Player 2</label>
					<input 
						type="text" 
						id="player2" 
						name="player2" 
						placeholder="Enter GitHub username"
						autocomplete="off"
					/>
				</div>

				<button id="battleBtn" type="button">⚔️ BATTLE!</button>
			</div>

			<div id="error" class="error" role="alert"></div>
			<div id="loading" class="loading"></div>
			<div id="results" class="results"></div>
		</main>

		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: 'Press Start 2P', cursive;
				background: #0a0a1a;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				position: relative;
				overflow-x: hidden;
			}

			/* CRT Scanline Effect */
			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: repeating-linear-gradient(
					0deg,
					rgba(0, 0, 0, 0.15) 0px,
					rgba(0, 0, 0, 0.15) 1px,
					transparent 1px,
					transparent 2px
				);
				pointer-events: none;
				z-index: 9999;
				animation: scanline 8s linear infinite;
			}

			@keyframes scanline {
				0% {
					transform: translateY(0);
				}
				100% {
					transform: translateY(10px);
				}
			}

			main {
				background: rgba(10, 10, 26, 0.85);
				border: 3px solid #5fed83;
				box-shadow: 
					0 0 20px rgba(95, 237, 131, 0.5),
					inset 0 0 30px rgba(0, 0, 0, 0.5);
				padding: 40px;
				max-width: 700px;
				width: 100%;
				position: relative;
			}

			h1 {
				text-align: center;
				color: #5fed83;
				font-size: 2rem;
				margin-bottom: 10px;
				text-shadow:
					0 0 5px #5fed83,
					0 0 10px #5fed83,
					0 0 20px #5fed83,
					0 0 40px #5fed83,
					0 0 80px #5fed83;
				animation: neonPulse 2s ease-in-out infinite;
				letter-spacing: 2px;
			}

			@keyframes neonPulse {
				0%, 100% {
					text-shadow:
						0 0 5px #5fed83,
						0 0 10px #5fed83,
						0 0 20px #5fed83,
						0 0 40px #5fed83,
						0 0 80px #5fed83;
				}
				50% {
					text-shadow:
						0 0 2px #5fed83,
						0 0 5px #5fed83,
						0 0 10px #5fed83,
						0 0 20px #5fed83,
						0 0 40px #5fed83;
				}
			}

			.subtitle {
				text-align: center;
				color: #8a2be2;
				margin-bottom: 40px;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-shadow:
					0 0 5px #8a2be2,
					0 0 10px #8a2be2;
			}

			.battle-form {
				display: flex;
				flex-direction: column;
				gap: 30px;
			}

			.input-group {
				display: flex;
				flex-direction: column;
				gap: 12px;
				opacity: 0;
				animation: floatIn 0.8s ease-out forwards;
			}

			.input-group:first-child {
				animation-delay: 0.2s;
			}

			.input-group:last-of-type {
				animation-delay: 0.4s;
			}

			@keyframes floatIn {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			label {
				font-weight: 600;
				color: #5fed83;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 2px;
				text-shadow: 0 0 5px #5fed83;
			}

			input {
				padding: 16px;
				background: rgba(10, 10, 26, 0.8);
				border: 2px solid #5fed83;
				color: #e0e0e0;
				font-size: 0.8rem;
				font-family: 'Press Start 2P', cursive;
				transition: all 0.3s;
				box-shadow: 0 0 10px rgba(95, 237, 131, 0.3);
			}

			input::placeholder {
				color: rgba(224, 224, 224, 0.4);
			}

			input:focus {
				outline: none;
				border-color: #8a2be2;
				box-shadow: 
					0 0 15px rgba(138, 43, 226, 0.6),
					inset 0 0 10px rgba(138, 43, 226, 0.2);
			}

			.vs {
				text-align: center;
				font-weight: bold;
				font-size: 2rem;
				padding: 20px;
				background: linear-gradient(90deg, #5fed83, #8a2be2, #5fed83);
				background-size: 200% 100%;
				-webkit-background-clip: text;
				background-clip: text;
				-webkit-text-fill-color: transparent;
				animation: gradientShift 3s ease infinite;
				text-shadow: none;
				position: relative;
				letter-spacing: 4px;
			}

			.vs::before {
				content: 'VS';
				position: absolute;
				left: 50%;
				top: 50%;
				transform: translate(-50%, -50%);
				-webkit-text-fill-color: rgba(95, 237, 131, 0.3);
				filter: blur(10px);
				z-index: -1;
			}

			@keyframes gradientShift {
				0%, 100% {
					background-position: 0% 50%;
				}
				50% {
					background-position: 100% 50%;
				}
			}

			button {
				background: rgba(10, 10, 26, 0.9);
				color: #5fed83;
				border: 3px solid #5fed83;
				padding: 20px 40px;
				font-size: 1rem;
				font-weight: bold;
				font-family: 'Press Start 2P', cursive;
				cursor: pointer;
				transition: all 0.3s;
				margin-top: 20px;
				box-shadow: 
					0 0 15px rgba(95, 237, 131, 0.5),
					inset 0 0 20px rgba(0, 0, 0, 0.5);
				text-shadow: 0 0 5px #5fed83;
				letter-spacing: 2px;
			}

			button:hover:not(:disabled) {
				transform: scale(1.05);
				box-shadow: 
					0 0 30px rgba(95, 237, 131, 0.8),
					inset 0 0 20px rgba(95, 237, 131, 0.2);
				text-shadow: 
					0 0 5px #5fed83,
					0 0 10px #5fed83,
					0 0 20px #5fed83;
			}

			button:active:not(:disabled) {
				transform: scale(0.95);
			}

			button:disabled {
				opacity: 0.5;
				cursor: not-allowed;
			}

			.error {
				display: none;
				background: rgba(255, 0, 0, 0.1);
				color: #ff4444;
				padding: 16px;
				margin-top: 20px;
				border: 2px solid #ff4444;
				font-size: 0.7rem;
				line-height: 1.6;
				box-shadow: 0 0 15px rgba(255, 68, 68, 0.3);
			}

			.error.show {
				display: block;
			}

			.loading {
				display: none;
				text-align: center;
				margin-top: 30px;
				font-size: 1rem;
				color: #5fed83;
				animation: colorShift 2s ease-in-out infinite;
				text-shadow: 0 0 10px currentColor;
			}

			.loading.show {
				display: block;
			}

			@keyframes colorShift {
				0%, 100% {
					color: #5fed83;
				}
				50% {
					color: #8a2be2;
				}
			}

			.loading::after {
				content: '...';
				animation: dots 1.5s steps(4, end) infinite;
			}

			@keyframes dots {
				0%, 20% { content: '.'; }
				40% { content: '..'; }
				60%, 100% { content: '...'; }
			}

			.results {
				display: none;
				margin-top: 30px;
			}

			.results.show {
				display: block;
			}

			.results-container {
				display: flex;
				flex-direction: column;
				gap: 20px;
				align-items: stretch;
				position: relative;
			}

			.player-result {
				background: rgba(10, 10, 26, 0.6);
				padding: 20px;
				border: 2px solid #5fed83;
				position: relative;
				overflow: hidden;
				box-shadow: 0 0 15px rgba(95, 237, 131, 0.3);
			}

			.player-result::before {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 200%;
				height: 200%;
				background: linear-gradient(
					90deg,
					transparent,
					rgba(255, 255, 255, 0.1),
					transparent
				);
				animation: shimmer 3s infinite;
			}

			@keyframes shimmer {
				0% {
					transform: translateX(-100%) translateY(-100%) rotate(45deg);
				}
				100% {
					transform: translateX(100%) translateY(100%) rotate(45deg);
				}
			}

			.player-result.winner {
				border-color: #8a2be2;
				box-shadow: 
					0 0 30px rgba(138, 43, 226, 0.6),
					inset 0 0 20px rgba(138, 43, 226, 0.2);
			}

			.player-result.winner::before {
				background: linear-gradient(
					90deg,
					transparent,
					rgba(138, 43, 226, 0.3),
					transparent
				);
				animation: shimmer 2s infinite;
			}

			.player-name {
				font-size: 1rem;
				font-weight: bold;
				margin-bottom: 15px;
				color: #e0e0e0;
				text-shadow: 0 0 5px rgba(95, 237, 131, 0.5);
			}

			.player-stats {
				font-size: 0.7rem;
				color: #5fed83;
				margin-bottom: 16px;
			}

			.stat-row {
				display: flex;
				justify-content: space-between;
				margin-bottom: 8px;
			}

			.stat-label {
				font-weight: 600;
				color: #5fed83;
			}

			.stat-value {
				color: #8a2be2;
				font-weight: bold;
				text-shadow: 0 0 5px #8a2be2;
			}

			.contribution-graph-label {
				font-size: 0.7rem;
				font-weight: 600;
				color: #8a2be2;
				margin-bottom: 10px;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}

			.contribution-grid {
				display: flex;
				flex-direction: column;
				gap: 3px;
				padding: 10px;
				background: rgba(0, 0, 0, 0.3);
				overflow-x: auto;
			}

			.contribution-week {
				display: flex;
				gap: 3px;
			}

			.contribution-day {
				width: 12px;
				height: 12px;
				cursor: pointer;
				transition: all 0.3s;
				border: 1px solid rgba(95, 237, 131, 0.2);
			}

			.contribution-day:hover {
				transform: scale(1.5);
				box-shadow: 0 0 10px currentColor;
				z-index: 10;
			}

			.grid-placeholder {
				padding: 20px;
				text-align: center;
				color: #666;
				background: rgba(0, 0, 0, 0.3);
				font-size: 0.7rem;
			}

			.vs-badge {
				text-align: center;
				font-weight: bold;
				font-size: 1.3rem;
				color: #5fed83;
				background: rgba(10, 10, 26, 0.9);
				padding: 12px 20px;
				border: 2px solid #5fed83;
				align-self: center;
				margin: -10px 0;
				z-index: 10;
				box-shadow: 0 0 20px rgba(95, 237, 131, 0.5);
				text-shadow: 0 0 10px #5fed83;
				animation: gradientShift 3s ease infinite;
				font-family: 'Press Start 2P', cursive;
			}

			.winner-badge {
				display: inline-block;
				background: #8a2be2;
				color: white;
				padding: 6px 12px;
				font-size: 0.6rem;
				font-weight: bold;
				margin-left: 10px;
				box-shadow: 0 0 15px rgba(138, 43, 226, 0.8);
				animation: badgePulse 1s ease-in-out infinite;
			}

			@keyframes badgePulse {
				0%, 100% {
					transform: scale(1);
				}
				50% {
					transform: scale(1.05);
				}
			}

			.battle-summary {
				text-align: center;
				margin-top: 20px;
				padding: 20px;
				background: rgba(138, 43, 226, 0.2);
				border: 2px solid #8a2be2;
				font-size: 0.8rem;
				font-weight: bold;
				color: #8a2be2;
				text-shadow: 0 0 10px #8a2be2;
				box-shadow: 0 0 20px rgba(138, 43, 226, 0.4);
				line-height: 1.6;
			}
		</style>

		<script is:inline>
			const player1Input = document.getElementById('player1');
			const player2Input = document.getElementById('player2');
			const battleBtn = document.getElementById('battleBtn');
			const errorDiv = document.getElementById('error');
			const loadingDiv = document.getElementById('loading');
			const resultsDiv = document.getElementById('results');

			// GitHub contribution color palette (based on levels 0-4)
			const CONTRIBUTION_COLORS = {
				0: '#ebedf0',
				1: '#c6e48b',
				2: '#40c463',
				3: '#30a14e',
				4: '#216e39'
			};

			function showError(message) {
				errorDiv.textContent = message;
				errorDiv.classList.add('show');
			}

			function hideError() {
				errorDiv.textContent = '';
				errorDiv.classList.remove('show');
			}

			function showLoading(message = 'Fetching battle data') {
				loadingDiv.textContent = message;
				loadingDiv.classList.add('show');
			}

			function hideLoading() {
				loadingDiv.textContent = '';
				loadingDiv.classList.remove('show');
			}

			function hideResults() {
				resultsDiv.innerHTML = '';
				resultsDiv.classList.remove('show');
			}

			async function fetchContributions(username) {
				const response = await fetch(`/api/contributions/${username}`);
				
				if (!response.ok) {
					const error = await response.json();
					throw new Error(error.error || `Failed to fetch data for ${username}`);
				}

				return await response.json();
			}

			function calculateTotalContributions(data) {
				if (!data || typeof data.total_contributions !== 'number') {
					console.error('Invalid contribution data structure:', data);
					return 0;
				}
				return data.total_contributions;
			}

			function renderContributionGrid(data, username) {
				if (!data || !Array.isArray(data.weeks) || data.weeks.length === 0) {
					return '<div class="grid-placeholder">No contribution data available</div>';
				}

				// Create grid HTML from weeks
				const weeksHTML = data.weeks.map(week => {
					if (!week || !Array.isArray(week.contribution_days)) {
						return '<div class="contribution-week"></div>';
					}
					const daysHTML = week.contribution_days.map(day => {
						if (!day) return '';
						const level = day.level || 0;
						const color = CONTRIBUTION_COLORS[level] || '#ebedf0';
						const dayName = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][day.weekday];
						return `<div class="contribution-day" style="background-color: ${color};" title="${dayName}: ${day.count} contributions"></div>`;
					}).join('');
					return `<div class="contribution-week">${daysHTML}</div>`;
				}).join('');

				return `<div class="contribution-grid">${weeksHTML}</div>`;
			}

			function getDateRange(data) {
				if (!data) {
					return { start: 'N/A', end: 'N/A' };
				}
				return {
					start: data.from || 'N/A',
					end: data.to || 'N/A'
				};
			}

			function displayResults(player1, player2) {
				const isPlayer1Winner = player1.totalContributions > player2.totalContributions;
				const isPlayer2Winner = player2.totalContributions > player1.totalContributions;
				const isTie = player1.totalContributions === player2.totalContributions;

				const player1Grid = renderContributionGrid(player1.data, player1.username);
				const player2Grid = renderContributionGrid(player2.data, player2.username);

				resultsDiv.innerHTML = `
					<div class="results-container">
						<div class="player-result ${isPlayer1Winner ? 'winner' : ''}">
							<div class="player-name">
								${player1.username}
								${isPlayer1Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
							</div>
							<div class="player-stats">
								<div class="stat-row">
									<span class="stat-label">Total Contributions:</span>
									<span class="stat-value">${player1.totalContributions.toLocaleString()}</span>
								</div>
								<div class="stat-row">
									<span class="stat-label">Period:</span>
									<span class="stat-value">${player1.dateRange.start} to ${player1.dateRange.end}</span>
								</div>
							</div>
							<div class="contribution-graph-label">Last Year Activity</div>
							${player1Grid}
						</div>

						<div class="vs-badge">VS</div>

						<div class="player-result ${isPlayer2Winner ? 'winner' : ''}">
							<div class="player-name">
								${player2.username}
								${isPlayer2Winner ? '<span class="winner-badge">🏆 WINNER</span>' : ''}
							</div>
							<div class="player-stats">
								<div class="stat-row">
									<span class="stat-label">Total Contributions:</span>
									<span class="stat-value">${player2.totalContributions.toLocaleString()}</span>
								</div>
								<div class="stat-row">
									<span class="stat-label">Period:</span>
									<span class="stat-value">${player2.dateRange.start} to ${player2.dateRange.end}</span>
								</div>
							</div>
							<div class="contribution-graph-label">Last Year Activity</div>
							${player2Grid}
						</div>
					</div>

					<div class="battle-summary">
						${isTie ? '🤝 It\'s a tie!' : 
							isPlayer1Winner ? `🎉 ${player1.username} wins with ${(player1.totalContributions - player2.totalContributions).toLocaleString()} more contributions!` : 
							`🎉 ${player2.username} wins with ${(player2.totalContributions - player1.totalContributions).toLocaleString()} more contributions!`}
					</div>
				`;

				resultsDiv.classList.add('show');
			}

			async function handleBattle() {
				const username1 = player1Input.value.trim();
				const username2 = player2Input.value.trim();

				hideError();
				hideResults();

				// Validate inputs
				if (!username1 || !username2) {
					showError('Please enter both usernames');
					return;
				}

				// Disable button and show loading
				battleBtn.disabled = true;
				showLoading();

				try {
					// Fetch both users' data in parallel
					const [data1, data2] = await Promise.all([
						fetchContributions(username1),
						fetchContributions(username2)
					]);

					// Validate data structure
					if (!data1 || typeof data1 !== 'object') {
						throw new Error(`Invalid data received for user ${username1}`);
					}
					if (!data2 || typeof data2 !== 'object') {
						throw new Error(`Invalid data received for user ${username2}`);
					}

					// Calculate totals and date ranges
					const dateRange1 = getDateRange(data1);
					const dateRange2 = getDateRange(data2);

					const player1Data = {
						username: username1,
						totalContributions: calculateTotalContributions(data1),
						data: data1,
						dateRange: dateRange1
					};

					const player2Data = {
						username: username2,
						totalContributions: calculateTotalContributions(data2),
						data: data2,
						dateRange: dateRange2
					};

					// Display results
					displayResults(player1Data, player2Data);

				} catch (error) {
					console.error('Battle error:', error);
					showError(error instanceof Error ? error.message : 'An error occurred during the battle');
				} finally {
					hideLoading();
					battleBtn.disabled = false;
				}
			}

			// Attach event listener
			battleBtn.addEventListener('click', handleBattle);

			// Allow Enter key in inputs
			[player1Input, player2Input].forEach(input => {
				input.addEventListener('keypress', (e) => {
					if (e.key === 'Enter') {
						handleBattle();
					}
				});
			});
		</script>
	</body>
</html>
