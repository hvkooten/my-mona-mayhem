					transform: translateX(100%) translateY(100%) rotate(45deg);
				}
			}

			.player-result.winner {
				border-color: #8a2be2;
				box-shadow: 
					0 0 30px rgba(138, 43, 226, 0.6),
					inset 0 0 20px rgba(138, 43, 226, 0.2);
			}

			.player-result.winner::before {
				background: linear-gradient(
					90deg,
					transparent,
					rgba(138, 43, 226, 0.3),
					transparent
				);
				animation: shimmer 2s infinite;
			}

			.player-name {
				font-size: 1rem;
				font-weight: bold;
				margin-bottom: 15px;
				color: #e0e0e0;
				text-shadow: 0 0 5px rgba(95, 237, 131, 0.5);
			}

			.player-stats {
				font-size: 0.7rem;
				color: #5fed83;
				margin-bottom: 16px;
			}

			.stat-row {
				display: flex;
				justify-content: space-between;
				margin-bottom: 8px;
			}

			.stat-label {
				font-weight: 600;
				color: #5fed83;
			}

			.stat-value {
				color: #8a2be2;
				font-weight: bold;
				text-shadow: 0 0 5px #8a2be2;
			}

			.contribution-graph-label {
				font-size: 0.7rem;
				font-weight: 600;
				color: #8a2be2;
				margin-bottom: 10px;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}

			.contribution-grid {
				display: flex;
				flex-direction: column;
				gap: 3px;
				padding: 10px;
				background: rgba(0, 0, 0, 0.3);
